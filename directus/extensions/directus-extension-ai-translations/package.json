{
  "name": "directus-extension-ai-translations",
  "version": "1.0.7",
  "description": "AI-powered translations interface that mirrors the native Directus translations interface",
  "keywords": [
    "directus",
    "directus-extension"
  ],
  "directus:extension": {
    "type": "bundle",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "interface",
        "name": "ai-translations",
        "source": "./src/interface/index.ts"
      },
      {
        "type": "endpoint",
        "name": "ai-translate",
        "source": "./src/endpoint/index.ts"
      }
    ],
    "host": "^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build --watch"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.0"
  }
}
