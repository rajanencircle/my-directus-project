{
  "name": "media-share-viewer",
  "version": "1.0.0",
  "directus:extension": {
    "type": "bundle",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "host": "^11.0.0",
    "entries": [
      {
        "type": "module",
        "name": "media-share-viewer",
        "source": "src/module/index.ts"
      },
      {
        "type": "interface",
        "name": "media-share-button",
        "source": "src/interface/index.ts"
      }
    ]
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build --watch"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "latest",
    "typescript": "latest",
    "vite": "^6.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.6.3"
  }
}
