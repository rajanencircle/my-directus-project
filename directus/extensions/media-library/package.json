{
  "name": "directus-extension-media-library",
  "version": "1.0.0",
  "description": "Custom media library module for Directus — full-page file browser with folder tree, grid/list views, and drag-and-drop upload.",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-module"
  ],
  "directus:extension": {
    "type": "module",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.0",
    "pinia": "^2.1.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.0.0"
  },
  "dependencies": {}
}
