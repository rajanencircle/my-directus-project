{
  "name": "save-and-stay-trigger-flow",
  "version": "1.0.3",
  "description": "Save and Stay + Trigger Flow button interface for Directus",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-interface"
  ],
  "directus:extension": {
    "type": "interface",
    "path": "dist/index.js",
    "source": "src/index.js",
    "host": "*"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "rb": "docker compose down && npm run build && docker compose up -d"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.1.3"
  }
}
