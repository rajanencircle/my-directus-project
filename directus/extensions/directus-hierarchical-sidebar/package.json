{
  "name": "directus-hierarchical-sidebar",
  "version": "1.0.0",
  "description": "Hierarchical sidebar extension for Directus that organizes collections based on parent-child relationships",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-module"
  ],
  "directus:extension": {
    "type": "module",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "*"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w",
    "link": "directus-extension link"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.5",
    "typescript": "^5.3.3",
    "vue": "^3.5.24"
  },
  "dependencies": {}
}