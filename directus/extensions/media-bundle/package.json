{
  "name": "media-bundle",
  "version": "1.0.0",
  "type": "module",
  "description": "Directus bundle — media-library module, media-uploader interface, media-share-viewer module + interface, and media-share-validate endpoint.",
  "directus:extension": {
    "type": "bundle",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "host": "^11.0.0",
    "entries": [
      {
        "type": "module",
        "name": "media-library",
        "source": "./media-library/src/index.ts"
      },
      {
        "type": "interface",
        "name": "media-uploader",
        "source": "./directus-extension-media-uploader/src/index.ts"
      },
      {
        "type": "module",
        "name": "media-share-viewer",
        "source": "./media-share-viewer/src/module/index.ts"
      },
      {
        "type": "interface",
        "name": "media-share-button",
        "source": "./media-share-viewer/src/interface/index.ts"
      },
      {
        "type": "endpoint",
        "name": "media-share-validate",
        "source": "./media-share-validate/src/index.ts"
      },
      {
        "type": "interface",
        "name": "file-albums",
        "source": "./directus-extension-interface-file-albums/src/index.ts"
      },
      {
        "type": "interface",
        "name": "file-media-extras",
        "source": "./directus-extension-file-media-extras/src/index.ts"
      }
    ]
  },
  "workspaces": [
    "media-library",
    "directus-extension-media-uploader",
    "media-share-viewer",
    "media-share-validate",
    "directus-extension-interface-file-albums",
    "directus-extension-file-media-extras"
  ],
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build --watch",
    "build:sub": "npm run build --workspaces --if-present",
    "build:all": "npm run build:sub && npm run build"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.0",
    "pinia": "^2.1.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.6.3"
  }
}
