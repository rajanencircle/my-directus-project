{
  "name": "directus-extension-api-docs",
  "version": "3.0.1",
  "description": "directus extension for swagger interface and openapi including custom endpoints definitions // custom endpoint validations middleware based on openapi or zod",
  "license": "MIT",
  "icon": "api",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!*.map",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-endpoint",
    "directus-custom-endpoint",
    "swagger",
    "custom endpoints",
    "openapi definition",
    "openapi",
    "validations",
    "api-validator",
    "zod",
    "type-safe"
  ],
  "directus:extension": {
    "type": "endpoint",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^9.0.0 || ^10.0.0 || ^11.0.0"
  },
  "scripts": {
    "test": "jest --verbose=true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ignore-path .gitignore --ext .ts tests/ src/",
    "lint:fix": "pnpm lint --fix",
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@pnpm/find-workspace-dir": "^1000.1.5",
    "express-openapi-validator": "^5.6.2",
    "js-yaml": "^4.1.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.1.4",
    "@directus/types": "^15.0.3",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^4.22.2",
    "jest": "^29.7.0",
    "jest-extended": "^3.2.4",
    "openapi-schema-validator": "^12.1.3",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vue": "^3.5.34"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
