{
  "name": "directus-extension-item-preview-button",
  "description": "Item preview button interface — configure fields, groups, and translations in one JSON",
  "version": "2.0.0",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-interface",
    "item-preview"
  ],
  "files": [
    "dist"
  ],
  "directus:extension": {
    "type": "interface",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "*"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.5",
    "typescript": "^5.3.3",
    "vue": "^3.5.24"
  }
}
